# Порт публикации на хосте (контейнер слушает 8000)
DIARIZE_PORT=8124

# Ключи доступа (Authorization: Bearer <key> или X-API-Key), через запятую.
# ПУСТО = аутентификация отключена.
DIARIZE_API_KEYS=change-me-key-1

# HF-токен с ПРИНЯТОЙ лицензией pyannote/speaker-diarization-community-1
# (обязателен для диаризации моно-аудио). Принять: https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# Модель диаризации (pyannote, gated)
DIAR_MODEL=pyannote/speaker-diarization-community-1

# ASR (onnx-asr скачает модели при первом старте в том /models)
DIARIZE_DEFAULT_MODEL=gigaam
GIGAAM_MODEL=gigaam-v3-e2e-rnnt
PARAKEET_MODEL=nemo-parakeet-tdt-0.6b-v3

# Лимит размера загрузки (байт), по умолчанию 1 GiB
MAX_UPLOAD_BYTES=1073741824
